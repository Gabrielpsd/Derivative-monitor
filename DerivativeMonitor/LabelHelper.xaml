<UserControl x:Class="DerivativeMonitor.LabelHelper"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DerivativeMonitor"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <StackPanel Orientation="Horizontal">

            <!-- the label text -->
            <TextBlock Text="{Binding LabelText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   VerticalAlignment="Center"/>

            <!-- the "?" marker with the tooltip -->
            <TextBlock Text="?"
                   Margin="4 0 0 0"
                   Foreground="Gray"
                   FontWeight="Bold"
                   Cursor="Help"
                   VerticalAlignment="Center"
                   ToolTipService.InitialShowDelay="200"
                   ToolTipService.ShowDuration="20000"
                   ToolTip="{Binding HelpText, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

        </StackPanel>
    </Grid>
</UserControl>
