<Window x:Class="WpfApp1.MainWindow"
        WindowState="Maximized"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" Loaded="Window_Loaded">
    <Grid>

        <!-- ROWS -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Top summary -->
            <RowDefinition Height="200"/>
            <RowDefinition Height="*"/>
            <!-- Tables -->
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <StackPanel
            Grid.Row="0"
            Orientation="Horizontal"
            Background="#1E1E2E"
            Margin="0">

            <!-- Ticker input + Load button grouped together -->
            <StackPanel Orientation="Horizontal" Margin="8 4">
                <TextBox x:Name="TickerInput"
                         Width="80"
                         Margin="0 0 6 0"
                         VerticalContentAlignment="Center"
                         IsEnabled="False"/>

                <Button x:Name="LoadButton"
                        Content="Load"
                        Click="Load_Click"
                        Width="30"
                        Height="25"
                        Margin="2"/>

                <Button x:Name="ServerStart"
                        Click="ServerStart_click"
                        Width="40"
                        Height="25" ToolTip="Iniciar Servidor RTD"
                    >
                    
                    <TextBlock x:Name="ConnectServerButtonTextBlock"
                                Text="&#xE7E8;" 
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="16"
                                Foreground="Black"
                               />
                </Button>
                <Button x:Name="ConnectDataLoopButton"
                        Click="ConnectDataLoop"
                        Width="30"
                        Height="25" ToolTip="Conectar Dados" 
                        
                        >
                    <TextBlock x:Name="ConnectDataLoopButtonTextBlock"
                        Text="&#xE8CE;" 
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="16"
                        Foreground="Black"/>
                </Button>
            </StackPanel>

            <!-- Divider -->
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                       Margin="4 4"/>

            <!-- Price info grouped together -->
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="8 0">

                <Label Content="Fechamento:"
                       Foreground="White"
                       FontSize="13"
                       VerticalAlignment="Center"/>

                <Label x:Name="LabelClose"
                       Content="0.00"
                       Foreground="#00FF99"
                       FontSize="16"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
            </StackPanel>

        </StackPanel>
        <Border Grid.Row="1"
                Margin="8 4"
                BorderBrush="#444"
                BorderThickness="1"
                CornerRadius="4"
                Background="#12121F">

            <!-- 🔧 Replace this with your real chart control later -->
            <Label Content="[ Chart goes here ]"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="#555"
                   FontSize="16"/>

        </Border>

        <!-- MAIN AREA -->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- CALLS -->
            <GroupBox Header="CALL OPTIONS"
                  Grid.Column="0"
                  Margin="4">

                <DataGrid ItemsSource="{Binding CallOptions}"
                      AutoGenerateColumns="False">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Simbolo" Binding="{Binding Codigo}" Width="120"/>
                        <DataGridTextColumn Header="Preço" Binding="{Binding PrecoExercicio}" Width="100"/>
                        <DataGridTextColumn Header="Venc" Binding="{Binding Vencimento}" Width="80"/>
                        <DataGridTextColumn Header="Estilo" Binding="{Binding Estilo}" Width="100"/>
                    </DataGrid.Columns>

                </DataGrid>
            </GroupBox>

            <!-- PUTS -->
            <GroupBox Header="PUT OPTIONS"
                  Grid.Column="2"
                  Margin="4">

                <DataGrid ItemsSource="{Binding PutOptions}"
                      AutoGenerateColumns="False">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Simbolo" Binding="{Binding Codigo}" Width="120"/>
                        <DataGridTextColumn Header="Preço" Binding="{Binding PrecoExercicio}" Width="100"/>
                        <DataGridTextColumn Header="Venc" Binding="{Binding Vencimento}" Width="80"/>
                        <DataGridTextColumn Header="Estilo" Binding="{Binding Estilo}" Width="100"/>
                    </DataGrid.Columns>

                </DataGrid>
            </GroupBox>

        </Grid>
    </Grid>
</Window>
